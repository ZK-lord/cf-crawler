{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "启动 Web 服务器",
            "type": "shell",
            "command": "python",
            "args": ["${workspaceFolder}/server.py"],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "PATH": "C:\\msys64\\ucrt64\\bin;${env:PATH}"
                }
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "运行 CF 爬虫 (deploy版本)",
            "type": "shell",
            "command": "${workspaceFolder}/deploy/运行.bat",
            "options": {
                "cwd": "${workspaceFolder}/deploy"
            },
            "problemMatcher": []
        }
    ]
}
